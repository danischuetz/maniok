{
    "compilerOptions": {
        "module": "nodenext",
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "verbatimModuleSyntax": true
    },
    "include": ["src/**/*"],
    "exclude": ["dist/**", "node_modules", ".svelte-kit/**"]
}
