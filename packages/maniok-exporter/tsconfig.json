{
    "compilerOptions": {
        "module": "nodenext",
        "moduleResolution": "nodenext",
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "noEmit": false,
        "verbatimModuleSyntax": true,
        "rootDir": "src",
        "outDir": "dist",
        "types": ["node"]
    },
    "include": ["src/**/*"],
    "exclude": ["dist/**", "node_modules"]
}
